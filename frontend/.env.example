# Copy to .env.local and adjust as needed. .env.local is gitignored.

# Where the frontend expects the backend API.
# In dev, leave unset to use the Vite proxy (/api -> http://localhost:5000).
# In prod, point at the deployed backend, e.g. https://api.solarapp.example.com/api
# VITE_API_BASE_URL=/api

# Set to "mock" to bypass the backend and use the hardcoded Pasadena response.
# Useful when the Flask server / GOOGLE_SOLAR_API_KEY isn't available.
VITE_API_MODE=http
