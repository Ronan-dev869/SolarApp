GOOGLE_SOLAR_API_KEY=your-google-cloud-api-key-here

# Amazon Location Service — v2 Geocode API (no Place Index required).
# Create an API key in the Location Service console scoped to
# geo-places:Geocode and paste it here.
AWS_LOCATION_API_KEY=your-amazon-location-api-key-here
AWS_LOCATION_REGION=us-west-2
